# ============================================================================
# DamaDam Bot - Environment Sample
# Copy this file to .env and fill your real values.
# IMPORTANT: Do NOT commit your real .env to Git.
# ============================================================================

# ----------------------------
# DamaDam Credentials (Primary)
# ----------------------------
DD_LOGIN_EMAIL=0utLawZ
DD_LOGIN_PASS=******

# ----------------------------
# DamaDam Credentials (Secondary - optional fallback)
# If primary login fails, bot will try these.
# ----------------------------
DD_LOGIN_EMAIL2=Dazzling_Mushk
DD_LOGIN_PASS2=*******

# ----------------------------
# Google Sheets
# ----------------------------
# Main sheet contains tabs: MsgList, PostQueue, InboxQueue, MsgHistory
DD_SHEET_ID=1jVD2WRiUVb70EJF3cI6-gOAr7K_-P8IFv2g3tki2mSs

# Optional: Profiles sheet (Phase 1 profile scraping output)
DD_PROFILES_SHEET_ID=1jVD2WRiUVb70EJF3cI6-gOAr7K_-P8IFv2g3tki2mSs

# Google service account JSON key filename/path
CREDENTIALS_FILE=credentials.json

# ----------------------------
# Bot Behavior
# ----------------------------
# Auto push to git after run (if you have that workflow enabled)
DD_AUTO_PUSH=0

# Page load timeout in seconds
DD_PAGE_LOAD_TIMEOUT=60

# Run browser in headless mode (1=headless, 0=visible)
DD_HEADLESS=1

# ----------------------------
# Optional: Overrides
# ----------------------------
# Uncomment to override defaults
# DD_DRY_RUN=0
# DD_DEBUG=0
# DD_POST_COOLDOWN_SECONDS=135
